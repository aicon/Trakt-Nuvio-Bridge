# Copy to .env and fill in your Trakt OAuth app values.
# Trakt app redirect URI must match TRAKT_REDIRECT_URI exactly.

HOST_PORT=4173
VERSION=latest

TRAKT_CLIENT_ID=your_64_character_trakt_client_id
TRAKT_CLIENT_SECRET=your_trakt_client_secret
TRAKT_REDIRECT_URI=http://192.168.1.100:4173/api/trakt/callback
TRAKT_CALLBACK_ORIGIN=http://192.168.1.100:4173

# Optional build metadata
# BUILD_DATE=2026-06-06
